pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        APP_NAME = 'jenkins-practice-app'
        OUTPUT_FILE = 'app-output.txt'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Checking out code for ${APP_NAME}"
                sh 'ls -l'
            }
        }

        stage('Build') {
            steps {
                sh 'mkdir -p target'
                sh 'cp app.txt target/$OUTPUT_FILE'
                sh 'echo "Application Name: $APP_NAME" >> target/$OUTPUT_FILE'
                sh 'echo "Build Number: $BUILD_NUMBER" >> target/$OUTPUT_FILE'
                sh 'echo "Build completed successfully"'
            }
        }

        stage('Test') {
            steps {
                sh 'test -f target/$OUTPUT_FILE'
                sh 'grep "Hello" target/$OUTPUT_FILE'
                sh 'echo "Test passed: file exists and contains Hello"'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'target/app-output.txt', fingerprint: true
            }
        }
    }
}
